<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>EnvironmentVariables</key>
	<dict>
		<key>CLAUDE_CONFIG_DIR</key>
		<string>/opt/bumba-harness/.claude</string>
		<key>DISABLE_AUTOUPDATER</key>
		<string>1</string>
		<key>HOME</key>
		<string>/opt/bumba-harness</string>
		<key>LANG</key>
		<string>en_US.UTF-8</string>
		<key>PATH</key>
		<string>/opt/bumba-harness/.local/bin:/opt/bumba-harness/agent-flat/agent/.venv/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
	</dict>
	<key>ExitTimeOut</key>
	<integer>30</integer>
	<key>HardResourceLimits</key>
	<dict>
		<key>NumberOfFiles</key>
		<integer>65536</integer>
	</dict>
	<key>KeepAlive</key>
	<dict>
		<key>NetworkState</key>
		<true/>
		<key>SuccessfulExit</key>
		<false/>
	</dict>
	<key>Label</key>
	<string>com.bumba.agent-bridge</string>
	<key>ProcessType</key>
	<string>Standard</string>
	<key>ProgramArguments</key>
	<array>
		<string>/opt/bumba-harness/agent-flat/agent/.venv/bin/python</string>
		<string>-m</string>
		<string>bridge</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>SoftResourceLimits</key>
	<dict>
		<key>NumberOfFiles</key>
		<integer>65536</integer>
	</dict>
	<key>StandardErrorPath</key>
	<string>/opt/bumba-harness/logs/bridge-stderr.log</string>
	<key>StandardOutPath</key>
	<string>/opt/bumba-harness/logs/bridge-stdout.log</string>
	<key>ThrottleInterval</key>
	<integer>30</integer>
	<key>UserName</key>
	<string>bumba-agent</string>
	<key>WorkingDirectory</key>
	<string>/opt/bumba-harness/agent-flat/agent</string>
</dict>
</plist>
