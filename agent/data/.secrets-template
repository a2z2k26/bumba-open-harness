# Bumba bridge .secrets template
# Copy to /opt/bumba-harness/data/.secrets on the runtime host and chmod 600.
# LaunchDaemons have NO Keychain access — every credential the bridge
# needs at runtime lives in this flat file.

# Discord
discord_token=
operator_discord_id=

# Notion
notion_api_token=

# Claude Code OAuth (rotates every ~6h via bridge/token_refresher.py)
claude_oauth_token=
claude_oauth_refresh_token=
claude_oauth_expires_at=0

# Codex CLI ChatGPT-OAuth (Sprint Codex-4, issue #1838; id_token added in
# Codex-7-followup, issue #1872). Seed by running `codex login` on the Mac
# mini, then `python3 -m agent.scripts.seed_codex_secrets` to print these
# four lines from the resulting ~/.codex/auth.json. Required when any
# [backends] role resolves to "codex"; the bridge fails-closed at boot if
# codex_oauth_token is empty.
codex_oauth_token=
codex_oauth_refresh_token=
codex_oauth_id_token=
codex_oauth_expires_at=0

# VAPI voice (voice_enabled=true requires both)
vapi_api_key=
vapi_webhook_secret=

# Mission Control API bearer token + GitHub webhook secret
api_token=
github_webhook_secret=

# OpenRouter backend/fallback (optional)
openrouter_api_key=

# Job-search tracking database (optional; job-search tools fail closed if unset)
notion_job_db_id=

# Dead-man's-switch ping URL (Sprint 07.09, optional)
healthcheck_bridge_url=
