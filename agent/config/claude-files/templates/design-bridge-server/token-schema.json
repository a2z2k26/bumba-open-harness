{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BUMBA Design Token Schema",
  "version": "1.0.0",
  "description": "Comprehensive schema for design tokens with semantic preservation",
  
  "definitions": {
    "metadata": {
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "created": { "type": "string", "format": "date-time" },
        "modified": { "type": "string", "format": "date-time" },
        "source": { "type": "string" },
        "fileKey": { "type": "string" },
        "fileName": { "type": "string" }
      }
    },
    
    "colorToken": {
      "type": "object",
      "required": ["value", "type"],
      "properties": {
        "value": { "type": "string" },
        "type": { "const": "color" },
        "hex": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}([0-9A-Fa-f]{2})?$" },
        "rgb": {
          "type": "object",
          "properties": {
            "r": { "type": "number", "minimum": 0, "maximum": 255 },
            "g": { "type": "number", "minimum": 0, "maximum": 255 },
            "b": { "type": "number", "minimum": 0, "maximum": 255 },
            "a": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "hsl": {
          "type": "object",
          "properties": {
            "h": { "type": "number", "minimum": 0, "maximum": 360 },
            "s": { "type": "number", "minimum": 0, "maximum": 100 },
            "l": { "type": "number", "minimum": 0, "maximum": 100 },
            "a": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "semantic": {
          "type": "object",
          "properties": {
            "role": { "type": "string" },
            "usage": { "type": "array", "items": { "type": "string" } },
            "wcag": {
              "type": "object",
              "properties": {
                "contrastRatio": { "type": "number" },
                "level": { "enum": ["AA", "AAA", "FAIL"] }
              }
            }
          }
        },
        "figmaId": { "type": "string" },
        "figmaKey": { "type": "string" }
      }
    },
    
    "typographyToken": {
      "type": "object",
      "required": ["value", "type"],
      "properties": {
        "value": { "type": "object" },
        "type": { "const": "typography" },
        "fontFamily": { "type": "string" },
        "fontWeight": { "type": "number" },
        "fontSize": {
          "type": "object",
          "properties": {
            "px": { "type": "number" },
            "rem": { "type": "number" },
            "em": { "type": "number" }
          }
        },
        "lineHeight": {
          "type": "object",
          "properties": {
            "px": { "type": "number" },
            "unitless": { "type": "number" },
            "percentage": { "type": "number" }
          }
        },
        "letterSpacing": {
          "type": "object",
          "properties": {
            "px": { "type": "number" },
            "em": { "type": "number" },
            "percentage": { "type": "number" }
          }
        },
        "textTransform": { "enum": ["none", "uppercase", "lowercase", "capitalize"] },
        "textDecoration": { "enum": ["none", "underline", "line-through"] },
        "textAlign": { "enum": ["left", "center", "right", "justify"] },
        "description": { "type": "string" },
        "category": { "enum": ["heading", "body", "caption", "label", "code"] },
        "responsive": {
          "type": "object",
          "properties": {
            "mobile": { "type": "object" },
            "tablet": { "type": "object" },
            "desktop": { "type": "object" }
          }
        },
        "figmaId": { "type": "string" },
        "figmaKey": { "type": "string" }
      }
    },
    
    "spacingToken": {
      "type": "object",
      "required": ["value", "type"],
      "properties": {
        "value": { "type": "number" },
        "type": { "const": "spacing" },
        "px": { "type": "number" },
        "rem": { "type": "number" },
        "scale": { "type": "number" },
        "description": { "type": "string" },
        "category": { "enum": ["padding", "margin", "gap", "grid"] },
        "usage": { "type": "array", "items": { "type": "string" } }
      }
    },
    
    "effectToken": {
      "type": "object",
      "required": ["value", "type"],
      "properties": {
        "value": { "type": "object" },
        "type": { "const": "effect" },
        "effectType": { "enum": ["dropShadow", "innerShadow", "blur", "backgroundBlur"] },
        "color": { "$ref": "#/definitions/colorToken" },
        "offset": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "radius": { "type": "number" },
        "spread": { "type": "number" },
        "blendMode": { "type": "string" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "description": { "type": "string" },
        "figmaId": { "type": "string" },
        "figmaKey": { "type": "string" }
      }
    },
    
    "radiusToken": {
      "type": "object",
      "required": ["value", "type"],
      "properties": {
        "value": { "type": "number" },
        "type": { "const": "radius" },
        "px": { "type": "number" },
        "percentage": { "type": "number" },
        "description": { "type": "string" },
        "category": { "enum": ["small", "medium", "large", "full", "none"] }
      }
    },
    
    "componentToken": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": { "const": "component" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "variants": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "properties": { "type": "object" },
              "states": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "properties": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "default": {},
              "required": { "type": "boolean" },
              "description": { "type": "string" },
              "values": { "type": "array" }
            }
          }
        },
        "slots": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "accepts": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "figmaId": { "type": "string" },
        "figmaKey": { "type": "string" },
        "figmaComponentSetId": { "type": "string" }
      }
    },
    
    "breakpointToken": {
      "type": "object",
      "required": ["value", "type"],
      "properties": {
        "value": { "type": "number" },
        "type": { "const": "breakpoint" },
        "name": { "type": "string" },
        "minWidth": { "type": "number" },
        "maxWidth": { "type": "number" },
        "description": { "type": "string" }
      }
    },
    
    "animationToken": {
      "type": "object",
      "required": ["value", "type"],
      "properties": {
        "value": { "type": "object" },
        "type": { "const": "animation" },
        "duration": { "type": "number" },
        "easing": { "type": "string" },
        "delay": { "type": "number" },
        "iterations": { "type": "number" },
        "direction": { "enum": ["normal", "reverse", "alternate", "alternate-reverse"] },
        "fillMode": { "enum": ["none", "forwards", "backwards", "both"] },
        "description": { "type": "string" }
      }
    }
  },
  
  "type": "object",
  "required": ["metadata", "tokens"],
  "properties": {
    "metadata": { "$ref": "#/definitions/metadata" },
    "tokens": {
      "type": "object",
      "properties": {
        "colors": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/colorToken" }
        },
        "typography": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/typographyToken" }
        },
        "spacing": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/spacingToken" }
        },
        "effects": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/effectToken" }
        },
        "radius": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/radiusToken" }
        },
        "components": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/componentToken" }
        },
        "breakpoints": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/breakpointToken" }
        },
        "animations": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/animationToken" }
        }
      }
    },
    "relationships": {
      "type": "object",
      "properties": {
        "aliases": {
          "type": "object",
          "description": "Token aliases for semantic naming"
        },
        "compositions": {
          "type": "object",
          "description": "Composite tokens built from primitives"
        },
        "inheritance": {
          "type": "object",
          "description": "Token inheritance chains"
        }
      }
    }
  }
}