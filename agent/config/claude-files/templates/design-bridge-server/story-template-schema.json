{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Story Template Schema",
  "description": "Schema for Design Bridge story generation templates",
  "type": "object",
  "properties": {
    "component": {
      "type": "object",
      "description": "Component metadata",
      "properties": {
        "name": {
          "type": "string",
          "description": "Component name",
          "example": "Button"
        },
        "framework": {
          "type": "string",
          "enum": ["react", "vue", "angular", "svelte", "react-native", "flutter", "swiftui", "jetpack-compose"],
          "description": "Target framework"
        },
        "path": {
          "type": "string",
          "description": "Path to component file",
          "example": ".design/extracted-code/react/components/Button/Button.tsx"
        },
        "variants": {
          "type": "array",
          "description": "Component variants",
          "items": {
            "type": "string"
          },
          "example": ["primary", "secondary", "outline", "ghost"]
        },
        "props": {
          "type": "object",
          "description": "Component props/properties",
          "patternProperties": {
            ".*": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["string", "number", "boolean", "enum", "object", "array"],
                  "description": "Prop type"
                },
                "values": {
                  "type": "array",
                  "description": "Enum values (if type is enum)",
                  "items": {
                    "type": "string"
                  }
                },
                "default": {
                  "description": "Default value for prop"
                },
                "optional": {
                  "type": "boolean",
                  "description": "Whether prop is optional"
                },
                "description": {
                  "type": "string",
                  "description": "Prop description"
                }
              },
              "required": ["type"]
            }
          },
          "example": {
            "label": {
              "type": "string",
              "default": "Click me",
              "description": "Button label text"
            },
            "size": {
              "type": "enum",
              "values": ["sm", "md", "lg"],
              "default": "md",
              "description": "Button size"
            },
            "disabled": {
              "type": "boolean",
              "default": false,
              "optional": true,
              "description": "Whether button is disabled"
            }
          }
        }
      },
      "required": ["name", "framework", "path"]
    },
    "story": {
      "type": "object",
      "description": "Story configuration",
      "properties": {
        "title": {
          "type": "string",
          "description": "Story title in Storybook",
          "example": "Components/Button"
        },
        "decorators": {
          "type": "array",
          "description": "Story decorators",
          "items": {
            "type": "string"
          },
          "example": ["withTheme", "withRouter"]
        },
        "parameters": {
          "type": "object",
          "description": "Story parameters",
          "properties": {
            "layout": {
              "type": "string",
              "enum": ["centered", "fullscreen", "padded"],
              "description": "Story layout"
            },
            "design": {
              "type": "object",
              "description": "Figma design link",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "figma"
                },
                "url": {
                  "type": "string",
                  "format": "uri",
                  "description": "Figma file URL"
                }
              }
            },
            "backgrounds": {
              "type": "object",
              "description": "Background options"
            },
            "viewport": {
              "type": "object",
              "description": "Viewport configuration"
            }
          }
        },
        "argTypes": {
          "type": "object",
          "description": "Storybook argTypes (controls)",
          "patternProperties": {
            ".*": {
              "type": "object",
              "properties": {
                "control": {
                  "type": "string",
                  "enum": ["text", "number", "boolean", "select", "radio", "color", "date", "object", "array"],
                  "description": "Control type"
                },
                "options": {
                  "type": "array",
                  "description": "Options for select/radio controls"
                },
                "description": {
                  "type": "string",
                  "description": "Control description"
                }
              }
            }
          }
        },
        "defaultArgs": {
          "type": "object",
          "description": "Default args for all stories"
        }
      },
      "required": ["title"]
    },
    "metadata": {
      "type": "object",
      "description": "Generation metadata",
      "properties": {
        "generatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Generation timestamp"
        },
        "generator": {
          "type": "string",
          "const": "Design Bridge Story Generator",
          "description": "Generator name"
        },
        "version": {
          "type": "string",
          "description": "Generator version",
          "example": "1.0.0"
        }
      }
    }
  },
  "required": ["component", "story"],
  "example": {
    "component": {
      "name": "Button",
      "framework": "react",
      "path": ".design/extracted-code/react/components/Button/Button.tsx",
      "variants": ["primary", "secondary", "outline"],
      "props": {
        "label": {
          "type": "string",
          "default": "Click me",
          "description": "Button label text"
        },
        "size": {
          "type": "enum",
          "values": ["sm", "md", "lg"],
          "default": "md",
          "description": "Button size"
        },
        "disabled": {
          "type": "boolean",
          "default": false,
          "optional": true
        }
      }
    },
    "story": {
      "title": "Components/Button",
      "decorators": ["withTheme"],
      "parameters": {
        "layout": "centered",
        "design": {
          "type": "figma",
          "url": "https://figma.com/file/..."
        }
      },
      "argTypes": {
        "label": {
          "control": "text",
          "description": "Button label"
        },
        "size": {
          "control": "select",
          "options": ["sm", "md", "lg"]
        },
        "disabled": {
          "control": "boolean"
        }
      },
      "defaultArgs": {
        "label": "Click me",
        "size": "md",
        "disabled": false
      }
    },
    "metadata": {
      "generatedAt": "2025-11-20T00:00:00.000Z",
      "generator": "Design Bridge Story Generator",
      "version": "1.0.0"
    }
  }
}
